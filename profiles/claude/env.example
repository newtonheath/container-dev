# === Claude Authentication ===
# Your machine's auth type is auto-detected by start.sh, but you can override:
# FORCE_CLAUDE_AUTH=vertex  # Options: vertex, api, web

# --- For Vertex AI auth ---
# Used when: gcloud ADC file exists on host
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
CLOUD_ML_REGION=us-central1

# --- For API key auth ---
# Used when: ANTHROPIC_API_KEY is set
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# --- For web OAuth auth ---
# Used when: No gcloud ADC and no API key
# No env vars needed - OAuth token is stored in persistent volume
# First run will open browser for authentication
